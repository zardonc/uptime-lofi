{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "dev:dashboard": "wrangler dev src/index.ts",
    "dev:probe": "wrangler dev -c probe-wrangler.toml",
    "deploy": "wrangler deploy --minify src/index.ts",
    "deploy:dashboard": "wrangler deploy --minify src/index.ts",
    "deploy:probe": "wrangler deploy -c probe-wrangler.toml",
    "deploy:all": "npm run deploy:probe && npm run deploy:dashboard",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240320.0",
    "typescript": "^5.0.4",
    "vitest": "^4.1.2",
    "wrangler": "^4.76.0"
  }
}
