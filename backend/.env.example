# Environment bindings for the backend API (Cloudflare Workers)

# Database binding (D1)
DB=your-d1-database-name

# API secret key for JWT validation
API_SECRET_KEY=your_api_secret_key

# JWT audience and issuer for added validation
JWT_AUDIENCE=your_audience
JWT_ISSUER=your_issuer

# Comma-separated list of production allowed origins for CORS
# Example: https://example.com,https://api.example.com
CORS_ORIGINS=

# Emergency unlock key (optional, for break-glass access)
# If set, allows login when UI lock password is lost
# Must be different from API_SECRET_KEY
# EMERGENCY_UNLOCK_KEY=
